{
  "name": "ccclone",
  "version": "0.1.0",
  "type": "module",
  "description": "A minimal clone of Claude Code — terminal-based interactive coding assistant",
  "main": "dist/cli.js",
  "bin": {
    "ccclone": "dist/cli.js"
  },
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsup src/cli.ts --format esm"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "commander": "^13.1.0",
    "marked": "^15.0.6",
    "marked-terminal": "^7.3.0"
  },
  "devDependencies": {
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
